# Motion-control-to-vision chassis position message.
# All timestamps use the common ROS clock.
# Coordinates are in the world/court frame:
# origin at court geometric center, +X along court length, +Y to robot-left.

# Time at which this message is published by the interface layer.
builtin_interfaces/Time publish_stamp

# Monotonically increasing sequence number generated by this publisher.
uint32 sequence_id

# Chassis center position in world/court frame. Unit: metre.
float64 x
float64 y
